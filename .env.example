# ─── Required ────────────────────────────────────────────────────────────────

# 64-character hex string (32 bytes) used for AES-256-GCM token encryption
# Generate: openssl rand -hex 32
CALDERA_ENCRYPTION_KEY=

# 64-character hex string for HMAC-signing OAuth state tokens and outbound webhooks
# Generate: openssl rand -hex 32
STATE_HMAC_SECRET=

# PostgreSQL connection string
DATABASE_URL=postgresql://caldera:changeme@localhost:5432/caldera

# Public-facing base URL (used in OAuth redirect URIs and provider webhook URLs)
PUBLIC_BASE_URL=https://api.caldera.example.com

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: ${PUBLIC_BASE_URL}/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft / Entra (Azure AD) ────────────────────────────────────────────
# Create at: portal.azure.com → App registrations
# Redirect URI: ${PUBLIC_BASE_URL}/v1/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# ─── Optional ─────────────────────────────────────────────────────────────────

# Redis URL (if set, enables Redis-backed rate limiting; otherwise Postgres)
# REDIS_URL=redis://localhost:6379

# Sentry error tracking DSN
# SENTRY_DSN=

# OpenTelemetry OTLP endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# HTTP port
PORT=3000
